#include <iostream>
#include <windows.h>

using namespace std;

int main() {
    SetConsoleCP(65001);
    SetConsoleOutputCP(65001);

    int a, b;
    cout << "Введіть перше число: ";
    cin >> a;
    cout << "Введіть друге число: ";
    cin >> b;

    int temp_a = abs(a);
    int temp_b = abs(b);

    if (temp_a == 0 || temp_b == 0) {
        cout << "НСД: " << (temp_a + temp_b) << endl;
    } else {
        do {
            if (temp_a > temp_b) {
                temp_a %= temp_b;
            } else {
                temp_b %= temp_a;
            }
        } while (temp_a != 0 && temp_b != 0);

        cout << "НСД: " << (temp_a + temp_b) << endl;
    }

    return 0;
}
