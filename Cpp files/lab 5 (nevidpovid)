#include <iostream>
#include <windows.h>
#include <iomanip>

using namespace std;

int main() {
    SetConsoleCP(65001);
    SetConsoleOutputCP(65001);

    long i = 0;
    int count = 0;

    cout << "Список щасливих квитків із сумою цифр 13:" << endl;

    do {
        int firstPart = i / 1000;
        int secondPart = i % 1000;

        int sum1 = (firstPart / 100) + (firstPart / 10 % 10) + (firstPart % 10);
        int sum2 = (secondPart / 100) + (secondPart / 10 % 10) + (secondPart % 10);

        if (sum1 == 13 && sum2 == 13) {
            cout << setfill('0') << setw(6) << i << "  ";
            count++;
            if (count % 8 == 0) cout << endl;
        }
        i++;
    } while (i <= 999999);

    cout << "\n\nВсього знайдено квитків: " << count << endl;

    return 0;
}
