#include <iostream>
#include <windows.h>

using namespace std;

int main() {
    SetConsoleCP(65001);
    SetConsoleOutputCP(65001);

    int k;
    char s;
    cout << "Введіть сторону ромба k та символ: ";
    cin >> k >> s;

    for (int i = 1; i <= k; i++) {
        for (int j = 1; j <= k - i; j++) cout << " ";
        for (int j = 1; j <= 2 * i - 1; j++) cout << s;
        cout << endl;
    }

    for (int i = k - 1; i >= 1; i--) {
        for (int j = 1; j <= k - i; j++) cout << " ";
        for (int j = 1; j <= 2 * i - 1; j++) cout << s;
        cout << endl;
    }
    return 0;
}
